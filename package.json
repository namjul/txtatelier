{
  "name": "txtatelier",
  "description": "Local-first file sync with Evolu - workspaces as centers",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "centers/*"
  ],
  "scripts": {
    "check": "bunx biome check .",
    "format": "bunx biome format --write .",
    "format:check": "bunx biome format .",
    "lint": "bunx biome lint .",
    "lint:fix": "bunx biome check --write .",
    "typecheck": "bunx tsc --noEmit",
    "relay": "tsx scripts/relay.ts"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.4",
    "@evolu/common": "^7.4.0",
    "@evolu/nodejs": "^2.4.0",
    "@types/bun": "latest",
    "@types/node": "^22.10.5",
    "better-sqlite3": "^12.6.2",
    "tsx": "^4.21.0"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
