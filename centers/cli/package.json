{
  "name": "@txtatelier/cli",
  "version": "0.0.0",
  "description": "CLI for txtatelier local-first file sync",
  "type": "module",
  "bin": {
    "txtatelier": "./dist/index.js"
  },
  "files": [
    "dist",
    "package.json"
  ],
  "scripts": {
    "build": "bun build src/index.ts --outdir dist --target node --format esm --external better-sqlite3",
    "prepublishOnly": "bun run build",
    "dev": "bun --watch src/index.ts",
    "start": "bun src/index.ts",
    "test": "bun test"
  },
  "dependencies": {
    "@evolu/common": "^7.4.0",
    "better-sqlite3": "^12.6.2",
    "chokidar": "^5.0.0",
    "env-paths": "^4.0.0",
    "picomatch": "^4.0.3",
    "specialist": "^2.0.0",
    "tsx": "^4.21.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/picomatch": "^4.0.2"
  },
  "engines": {
    "bun": ">=1.0.0"
  },
  "keywords": [
    "file-sync",
    "local-first",
    "evolu",
    "crdt",
    "distributed",
    "sync",
    "offline-first"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/namjul/txtatelier.git",
    "directory": "centers/cli"
  },
  "bugs": {
    "url": "https://github.com/namjul/txtatelier/issues"
  },
  "homepage": "https://github.com/namjul/txtatelier#readme",
  "license": "MIT"
}
