{
  "name": "@txtatelier/cli",
  "version": "0.0.0",
  "description": "CLI for txtatelier local-first file sync",
  "type": "module",
  "bin": {
    "txtatelier": "./dist/index.js"
  },
  "files": [
    "dist",
    "package.json"
  ],
  "scripts": {
    "build": "bun build src/index.ts --outdir dist --target node --format esm --external clipanion --external typanion",
    "prepublishOnly": "bun run build",
    "dev": "bun --watch src/index.ts",
    "dev:inspect": "bun --inspect --watch src/index.ts",
    "start": "bun src/index.ts",
    "test": "vitest run"
  },
  "dependencies": {
    "@evolu/common": "^7.4.0",
    "chokidar": "^5.0.0",
    "clipanion": "^4.0.0-rc.4",
    "env-paths": "^4.0.0",
    "picomatch": "^4.0.3",
    "proper-lockfile": "^4.1.2",
    "sql.js": "^1.13.0",
    "tsx": "^4.21.0",
    "untildify": "^6.0.0"
  },
  "devDependencies": {
    "@types/sql.js": "^1.4.9",
    "@types/picomatch": "^4.0.2",
    "vitest": "^4.1.0"
  },
  "engines": {
    "node": ">=22.5.0"
  },
  "keywords": [
    "file-sync",
    "local-first",
    "evolu",
    "crdt",
    "distributed",
    "sync",
    "offline-first"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/namjul/txtatelier.git",
    "directory": "centers/cli"
  },
  "bugs": {
    "url": "https://github.com/namjul/txtatelier/issues"
  },
  "homepage": "https://github.com/namjul/txtatelier#readme",
  "license": "MIT"
}
